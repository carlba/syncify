{
  "name": "typescript-template",
  "description": "A short project description",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "author": "carlba",
  "homepage": "https://github.com/carlba/typescript-template",
  "bugs": {
    "url": "https://github.com/carlba/typescript-template"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/typescript-template"
  },
  "scripts": {
    "build": "tsc",
    "build-watch": "tsc --watch",
    "start": "node --env-file-if-exists='.env' dist/index.js",
    "start:dev": "tsx --env-file-if-exists=.env --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u",
    "linux:install": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye npm install",
    "linux:ci": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye bash -lc \"npm ci && npm run lint && npm test && npm run build\""
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "npm-check-updates": "^21.0.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
