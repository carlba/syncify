{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {

    "rootDir": "./src",
    "sourceMap": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true, // Enforces .js for modules
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
